{
  "expo": {
    "name": "Rwanda FDA",
    "slug": "rwanda-fda",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rwandafda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/RwandaFDA.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rwandafda.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Rwanda FDA uses Face ID to securely sign you in to your account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.rwandafda.app"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Rwanda FDA uses Face ID to securely sign you in."
        }
      ],
      "expo-asset"
    ]
  }
}
