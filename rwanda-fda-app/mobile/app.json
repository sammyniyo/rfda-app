{
  "expo": {
    "name": "Rwanda FDA",
    "slug": "rwanda-fda",
    "version": "1.0.0",
    "description": "Rwanda FDA staff app for tasks, applications, and monitoring.",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rwandafda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/RwandaFDA.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rwandafda.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Rwanda FDA uses Face ID to securely sign you in to your account.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rwandafda.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#0d6b52",
          "defaultChannel": "rwanda-fda-alerts",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Rwanda FDA uses Face ID to securely sign you in to your account."
        }
      ],
      "expo-asset"
    ]
  }
}
